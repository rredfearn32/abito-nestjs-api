                }
              }
            }
          },
          "400": {
            "description": "Invalid ID format"
          },
          "401": {
            "description": "Unauthorized"
          },
          "404": {
            "description": "Goal not found"
          }
        },
        "security": [
          {
            "bearer": []
          }
        ],
        "summary": "Update a goal's properties (e.g. title)",
        "tags": [
          "Goals"
        ]
      }
    },
    "/goals/{goalId}/streaks": {
      "post": {
        "operationId": "GoalsController_createStreak",
        "parameters": [
          {
            "name": "goalId",
            "required": true,
            "in": "path",
            "description": "Numeric ID of the goal",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "201": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CreateStreakResponseDto"
                }
              }
            }
          },
          "400": {
            "description": "Invalid ID format, or a streak is already in progress"
          },
          "401": {
            "description": "Unauthorized"
          },
          "404": {
            "description": "Goal not found"
          }
        },
        "security": [
          {
            "bearer": []
          }
        ],
        "summary": "Start a new streak for a goal",
        "tags": [
          "Goals"
        ]
      }
    },
    "/goals/{goalId}/streaks/{streakId}": {
      "patch": {
        "operationId": "GoalsController_updateStreak",
        "parameters": [
          {
            "name": "goalId",
            "required": true,
            "in": "path",
            "description": "Numeric ID of the goal",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "streakId",
            "required": true,
            "in": "path",
            "description": "Numeric ID of the streak",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Updated streak"
          },
          "400": {
            "description": "Invalid ID format, or streak cannot be updated (not in progress / wrong type)"
          },
          "401": {
            "description": "Unauthorized"
          },
          "404": {
            "description": "Goal not found"
          }
        },
        "security": [
          {
            "bearer": []
          }
        ],
        "summary": "Record a check-in on a streak for a START goal",
        "tags": [
          "Goals"
        ]
      },
      "delete": {
        "operationId": "GoalsController_endStreak",
        "parameters": [
          {
            "name": "goalId",
            "required": true,
            "in": "path",
            "description": "Numeric ID of the goal",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "streakId",
            "required": true,
            "in": "path",
            "description": "Numeric ID of the streak",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Ended streak"
          },
          "400": {
            "description": "Invalid ID format, or streak cannot be ended (not in progress / wrong type)"
          },
          "401": {
            "description": "Unauthorized"
          },
          "404": {
            "description": "Goal not found"
          }
        },
        "security": [
          {
            "bearer": []
          }
        ],
        "summary": "End an in-progress streak",
        "tags": [
          "Goals"
        ]
      }
    },
    "/cron/expire-start-streaks": {
      "post": {
        "operationId": "CronController_expireStreaks",
        "parameters": [],
        "responses": {
          "200": {
            "description": ""
          }
        },
        "summary": "Expire stale in-progress streaks",
        "tags": [
          "Cron"
        ]
      }
    }
  },
  "info": {
    "title": "Abito API",
    "description": "An API for Abito.dev",
    "version": "0.1",
    "contact": {}
  },
  "tags": [],
  "servers": [],
  "components": {
    "securitySchemes": {
      "bearer": {
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "type": "http",
        "description": "The Token used to communicate directly with the underlying API"
      }
    },
    "schemas": {
      "RegisterRequestDto": {
        "type": "object",
        "properties": {
          "username": {
            "type": "string"
          },
          "email": {
            "type": "string"
          },
          "password": {
            "type": "string"
          }
        },
        "required": [
          "username",
          "email",
          "password"
        ]
      },
      "AuthResponseDto": {
        "type": "object",
        "properties": {
          "userId": {
            "type": "string"
          },
          "username": {
            "type": "string"
          },
          "accessToken": {
            "type": "string"
          },
          "refreshToken": {
            "type": "string"
          }
        },
        "required": [
          "userId",
          "username",
          "accessToken",
          "refreshToken"
        ]
      },
      "LoginRequestDto": {
        "type": "object",
        "properties": {
          "username": {
            "type": "string"
          },
          "password": {
            "type": "string"
          }
        },
        "required": [
          "username",
          "password"
        ]
      },
      "RefreshRequestDto": {
        "type": "object",
        "properties": {
          "refreshToken": {
            "type": "string"
          }
        },
        "required": [
          "refreshToken"
        ]
      },
      "UserResponseDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "username": {
            "type": "string"
          },
          "email": {
            "type": "string"
          }
        },
        "required": [
          "id",
          "username",
          "email"
        ]
      },
      "UpdateProfileRequestDto": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string"
          },
          "password": {
            "type": "string"
          }
        },
        "required": [
          "email",
          "password"
        ]
      },
      "GetAllGoalsResponseDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "type": {
            "type": "string"
          },
          "activeStreak": {
            "type": "object",
            "nullable": true
          }
        },
        "required": [
          "id",
          "title",
          "type",
          "activeStreak"
        ]
      },
      "Streak": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "createdAt": {
            "format": "date-time",
            "type": "string"
          },
          "updatedAt": {
            "format": "date-time",
            "type": "string"
          },
          "inProgress": {
            "type": "boolean"
          },
          "goalId": {
            "type": "string"
          }
        },
        "required": [
          "id",
          "createdAt",
          "updatedAt",
          "inProgress",
          "goalId"
        ]
      },
      "GoalResponseDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "type": {
            "type": "string"
          },
          "activeStreak": {
            "nullable": true,
            "allOf": [
              {
                "$ref": "#/components/schemas/Streak"
              }
            ]
          },
          "previousStreaks": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Streak"
            }
          }
        },
        "required": [
          "id",
          "title",
          "type",
          "activeStreak",
          "previousStreaks"
        ]
      },
      "CreateGoalRequestDto": {
        "type": "object",
        "properties": {
          "title": {
            "type": "string"
          },
          "type": {
            "type": "string",
            "enum": [
              "START",
              "STOP"
            ]
          }
        },
        "required": [
          "title",
          "type"
        ]
      },
      "CreateGoalResponseDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "type": {
            "type": "string",
            "enum": [
              "START",
              "STOP"
            ]
          }
        },
        "required": [
          "id",
          "title",
          "type"
        ]
      },
      "DeleteGoalResponseDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "type": {
            "type": "string"
          }
        },
        "required": [
          "id",
          "title",
          "type"
        ]
      },
      "UpdateGoalDto": {
        "type": "object",
        "properties": {
          "title": {
            "type": "string"
          }
        },
        "required": [
          "title"
        ]
      },
      "CreateStreakResponseDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "createdAt": {
            "type": "string"
          },
          "updatedAt": {
            "type": "string"
          },
          "inProgress": {
            "type": "boolean"
          },
          "goalId": {
            "type": "string"
          }
        },
        "required": [
          "id",
          "createdAt",
          "updatedAt",
          "inProgress",
          "goalId"
        ]
      }
    }
  }
}