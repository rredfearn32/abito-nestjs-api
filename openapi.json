    "/goals/{goalId}": {
      "get": {
        "operationId": "GoalsController_getGoalById",
        "parameters": [
          {
            "name": "goalId",
            "required": true,
            "in": "path",
            "description": "Numeric ID of the goal",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/GoalResponseDto"
                }
              }
            }
          },
          "400": {
            "description": "Invalid ID format"
          },
          "401": {
            "description": "Unauthorized"
          },
          "404": {
            "description": "Goal not found"
          }
        },
        "security": [
          {
            "bearer": []
          }
        ],
        "summary": "Get a goal by ID",
        "tags": [
          "Goals"
        ]
      },
      "delete": {
        "operationId": "GoalsController_deleteGoal",
        "parameters": [
